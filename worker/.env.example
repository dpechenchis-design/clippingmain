# Same Postgres the Vercel app uses — the worker writes results straight to it.
DATABASE_URL=

# Anthropic key — clip discovery (finding viral moments) runs on Claude.
ANTHROPIC_API_KEY=

# Model for clip discovery. Default: claude-opus-4-8.
# CLIP_MODEL=claude-opus-4-8

# OpenAI key — used ONLY for Whisper transcription (audio -> timecoded text).
# Anthropic has no speech-to-text API, so this step still needs OpenAI.
OPENAI_API_KEY=

# Same Vercel Blob token the app uses — worker uploads finished clips here.
BLOB_READ_WRITE_TOKEN=

# Shared secret. Set the SAME value as WORKER_SECRET in the Vercel app so only
# it can trigger jobs. Generate one: `openssl rand -hex 32`
WORKER_SECRET=

# Optional. Audio chunk size (seconds) per Whisper request. Default 600 (10 min)
# keeps each request well under the 25MB API limit for any video length.
# TRANSCRIBE_CHUNK_SECONDS=600

# Port (Railway/Fly set this automatically).
# PORT=8080
